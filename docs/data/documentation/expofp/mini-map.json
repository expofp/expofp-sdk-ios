{"identifier":{"url":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/Mini-map","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Embed a floor plan preview in your content screens and expand it into a full interactive map on tap."}],"metadata":{"roleHeading":"Article","modules":[{"name":"ExpoFP"}],"role":"article","title":"Mini-Map"},"hierarchy":{"paths":[["doc:\/\/com.expofp.sdk\/documentation\/ExpoFP"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/expofp\/mini-map"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"A mini-map is a floor plan preview embedded directly in your app — right where attendees are already looking. Tap an exhibitor and see exactly where their booth is. Tap again to expand into a full interactive map with wayfinding directions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"https:\/\/www.youtube.com\/watch?v=4lCnvIRL22I","isActive":true,"type":"reference"}],"type":"paragraph"},{"inlineContent":[{"text":"The example follows a three-screen flow:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Exhibitors List","type":"text"}],"type":"strong"},{"text":" — loads exhibitors from the SDK and renders them as a scrollable list.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Exhibitor Detail","type":"text"}],"type":"strong"},{"text":" — shows an inline floor plan preview with the selected booth highlighted, plus Expand and Directions buttons.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Fullscreen Plan","type":"text"}]},{"text":" — the mini-map expands into a full interactive plan with Collapse and Directions controls.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"mini-map-wireframe.svg","type":"image"}],"type":"paragraph"},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"inlineContent":[{"text":"The full source is in the ","type":"text"},{"identifier":"https:\/\/github.com\/expofp\/expofp-sdk-ios-examples","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["git clone https:\/\/github.com\/expofp\/expofp-sdk-ios-examples.git","cd expofp-sdk-ios-examples\/MiniMap","open MiniMap.xcodeproj"],"type":"codeListing"},{"inlineContent":[{"text":"Build and run on a simulator or device (Xcode 16+, iOS 17+).","type":"text"}],"type":"paragraph"},{"level":2,"text":"Architecture","anchor":"Architecture","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The pattern uses ","type":"text"},{"inlineContent":[{"text":"two independent","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan","type":"reference"},{"text":" presenter instances created once and kept alive for the lifetime of the screen:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"miniMap"},{"text":" — powers the inline thumbnail. Touch input is disabled so it acts as a static preview.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"map"},{"text":" — powers the fullscreen interactive view.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Both load the same expo key but operate entirely independently. SwiftUI’s ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":" animates the frame from the inline position to fullscreen.","type":"text"}]},{"syntax":"swift","code":["@MainActor","final class ContentStore: ObservableObject {","    let miniMap = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","    let map = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","}"],"type":"codeListing"},{"text":"Plan ready → load exhibitors","level":2,"type":"heading","anchor":"Plan-ready-%E2%86%92-load-exhibitors"},{"type":"paragraph","inlineContent":[{"text":"Observe ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","type":"reference"},{"text":" on the mini-map presenter. When it first reaches ","type":"text"},{"code":".ready","type":"codeVoice"},{"text":", strip the default SDK controls from both presenters and fetch the exhibitor list.","type":"text"}]},{"syntax":"swift","code":[".onReceive(store.miniMap.planStatusPublisher) { status in","    self.status = status","","    if status == .ready && exhibitors.isEmpty {","        let visibility = ExpoFpElementsVisibility(","            controls: false,","            levels: false,","            header: false,","            overlay: false","        )","        store.miniMap.setElementsVisibility(visibility)","        store.map.setElementsVisibility(visibility)","","        Task {","            exhibitors = try await store.miniMap.exhibitorsList().get()","        }","    }","}"],"type":"codeListing"},{"text":"Embed the mini-map and handle interactions","level":2,"type":"heading","anchor":"Embed-the-mini-map-and-handle-interactions"},{"type":"paragraph","inlineContent":[{"text":"Place the mini-map view inline, disable hit-testing, and attach ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":". When the detail view appears, highlight the booth on both presenters so the correct booth is highlighted whether you are looking at the thumbnail or the fullscreen map.","type":"text"}]},{"syntax":"swift","code":["store.miniMap.getView()","    .frame(height: 200)","    .allowsHitTesting(false)","    .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: !showPlan)","    .onAppear {","        store.miniMap.selectExhibitor(nameOrExternalId: exhibitor.externalId)","        store.map.selectExhibitor(nameOrExternalId: exhibitor.externalId)","    }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"Expand","type":"text"}],"type":"strong"},{"text":" button animates to fullscreen; the ","type":"text"},{"inlineContent":[{"text":"Directions","type":"text"}],"type":"strong"},{"text":" button both expands and draws a wayfinding route:","type":"text"}]},{"syntax":"swift","code":["\/\/ Expand","Button {","    withAnimation(.easeInOut) { showPlan = true }","} label: {","    Image(systemName: \"arrow.up.left.and.arrow.down.right\")","}","","\/\/ Directions","Button {","    withAnimation(.easeInOut) {","        showPlan = true","        store.map.selectRoute(from: .booth(\"Entrance\"), to: .booth(exhibitor.externalId))","    }","} label: {","    HStack(spacing: 4) {","        Image(.directions)","        Text(\"Directions\").foregroundStyle(.black)","    }","}"],"type":"codeListing"},{"text":"Show the fullscreen plan","level":2,"type":"heading","anchor":"Show-the-fullscreen-plan"},{"type":"paragraph","inlineContent":[{"text":"Overlay the fullscreen presenter view and mirror the ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":" identifier so SwiftUI connects the two frames. The Collapse button calls ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/fitBounds(bounds:options:)","type":"reference"},{"text":" to reset the zoom before animating back.","type":"text"}]},{"syntax":"swift","code":["if showPlan {","    store.map.getView()","        .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: showPlan)","        .ignoresSafeArea()","        .overlay(alignment: .topLeading) {","            Button {","                withAnimation(.easeInOut) {","                    showPlan = false","                    store.map.fitBounds(bounds: nil, options: nil)","                }","            } label: {","                Image(systemName: \"arrow.down.right.and.arrow.up.left\")","                    .padding()","                    .background(.thinMaterial, in: Circle())","            }","            .padding()","        }","}"],"type":"codeListing"},{"text":"SDK APIs Used","level":2,"type":"heading","anchor":"SDK-APIs-Used"},{"header":"row","rows":[[[{"inlineContent":[{"text":"API","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Purpose","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan\/createPlanPresenter(with:additionalParams:locationProvider:messageListener:isDebugModeEnabled:)","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Create a presenter bound to an expo key","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Publisher that emits plan loading status changes","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/setElementsVisibility(_:)","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Hide\/show default SDK UI controls","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/exhibitorsList()","isActive":true,"type":"reference"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Fetch the list of exhibitors for the plan","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/getView()","isActive":true,"type":"referenc