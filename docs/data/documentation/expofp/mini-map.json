{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/Mini-map"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"A mini-map is a floor plan preview embedded directly in your app — right where attendees are already looking. Tap an exhibitor and see exactly where their booth is. Tap again to expand into a full interactive map with wayfinding directions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/www.youtube.com\/watch?v=4lCnvIRL22I"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example follows a three-screen flow:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Exhibitors List"}],"type":"strong"},{"text":" — loads exhibitors from the SDK and renders them as a scrollable list.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Exhibitor Detail"}],"type":"strong"},{"text":" — shows an inline floor plan preview with the selected booth highlighted, plus Expand and Directions buttons.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Fullscreen Plan"}]},{"type":"text","text":" — the mini-map expands into a full interactive plan with Collapse and Directions controls."}]}]}]},{"inlineContent":[{"type":"image","identifier":"mini-map-wireframe.svg"}],"type":"paragraph"},{"level":2,"text":"Quick Start","anchor":"Quick-Start","type":"heading"},{"inlineContent":[{"text":"The full source is in the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/expofp\/expofp-sdk-ios-examples","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["git clone https:\/\/github.com\/expofp\/expofp-sdk-ios-examples.git","cd expofp-sdk-ios-examples\/MiniMap","open MiniMap.xcodeproj"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"Build and run on a simulator or device (Xcode 16+, iOS 17+).","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Architecture","type":"heading","text":"Architecture"},{"inlineContent":[{"text":"The pattern uses ","type":"text"},{"inlineContent":[{"text":"two independent","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan","type":"reference"},{"text":" presenter instances created once and kept alive for the lifetime of the screen:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"miniMap","type":"codeVoice"},{"type":"text","text":" — powers the inline thumbnail. Touch input is disabled so it acts as a static preview."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"map","type":"codeVoice"},{"type":"text","text":" — powers the fullscreen interactive view."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Both load the same expo key but operate entirely independently. SwiftUI’s ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":" animates the frame from the inline position to fullscreen.","type":"text"}],"type":"paragraph"},{"code":["@MainActor","final class ContentStore: ObservableObject {","    let miniMap = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","    let map = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Plan-ready-%E2%86%92-load-exhibitors","type":"heading","text":"Plan ready → load exhibitors"},{"inlineContent":[{"text":"Observe ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","type":"reference"},{"text":" on the mini-map presenter. When it first reaches ","type":"text"},{"code":".ready","type":"codeVoice"},{"text":", strip the default SDK controls from both presenters and fetch the exhibitor list.","type":"text"}],"type":"paragraph"},{"code":[".onReceive(store.miniMap.planStatusPublisher) { status in","    self.status = status","","    if status == .ready && exhibitors.isEmpty {","        let visibility = ExpoFpElementsVisibility(","            controls: false,","            levels: false,","            header: false,","            overlay: false","        )","        store.miniMap.setElementsVisibility(visibility)","        store.map.setElementsVisibility(visibility)","","        Task {","            exhibitors = try await store.miniMap.exhibitorsList().get()","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Embed-the-mini-map-and-handle-interactions","type":"heading","text":"Embed the mini-map and handle interactions"},{"inlineContent":[{"text":"Place the mini-map view inline, disable hit-testing, and attach ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":". When the detail view appears, highlight the booth on both presenters so the correct booth is highlighted whether you are looking at the thumbnail or the fullscreen map.","type":"text"}],"type":"paragraph"},{"code":["store.miniMap.getView()","    .frame(height: 200)","    .allowsHitTesting(false)","    .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: !showPlan)","    .onAppear {","        store.miniMap.selectExhibitor(nameOrExternalId: exhibitor.externalId)","        store.map.selectExhibitor(nameOrExternalId: exhibitor.externalId)","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"Expand","type":"text"}],"type":"strong"},{"text":" button animates to fullscreen; the ","type":"text"},{"inlineContent":[{"text":"Directions","type":"text"}],"type":"strong"},{"text":" button both expands and draws a wayfinding route:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Expand","Button {","    withAnimation(.easeInOut) { showPlan = true }","} label: {","    Image(systemName: \"arrow.up.left.and.arrow.down.right\")","}","","\/\/ Directions","Button {","    withAnimation(.easeInOut) {","        showPlan = true","        store.map.selectRoute(from: .booth(\"Entrance\"), to: .booth(exhibitor.externalId))","    }","} label: {","    HStack(spacing: 4) {","        Image(.directions)","        Text(\"Directions\").foregroundStyle(.black)","    }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Show-the-fullscreen-plan","type":"heading","text":"Show the fullscreen plan"},{"inlineContent":[{"text":"Overlay the fullscreen presenter view and mirror the ","type":"text"},{"code":"matchedGeometryEffect","type":"codeVoice"},{"text":" identifier so SwiftUI connects the two frames. The Collapse button calls ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/fitBounds(bounds:options:)","type":"reference"},{"text":" to reset the zoom before animating back.","type":"text"}],"type":"paragraph"},{"code":["if showPlan {","    store.map.getView()","        .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: showPlan)","        .ignoresSafeArea()","        .overlay(alignment: .topLeading) {","            Button {","                withAnimation(.easeInOut) {","                    showPlan = false","                    store.map.fitBounds(bounds: nil, options: nil)","                }","            } label: {","                Image(systemName: \"arrow.down.right.and.arrow.up.left\")","                    .padding()","                    .background(.thinMaterial, in: Circle())","            }","            .padding()","        }","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"SDK-APIs-Used","type":"heading","text":"SDK APIs Used"},{"rows":[[[{"inlineContent":[{"type":"text","text":"API"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Purpose"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan\/createPlanPresenter(with:additionalParams:locationProvider:messageListener:isDebugModeEnabled:)","type":"reference","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"text":"Create a presenter bound to an expo key","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","type":"reference","isActive":true}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Publisher that emits plan loading status changes","type":"text"}]}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/setElementsVisibility(_:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Hide\/show default SDK UI controls"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/exhibitorsList()","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fetch the list of exhibitors for the plan"}]}]],[[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/getView()"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Get the SwiftUI view for the presenter","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/selectExhibitor(nameOrExternalId:)","type":"reference","isActive":true}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Highlight a booth by name or external ID"}]}]],[[{"inlineContent":[{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/selectRoute(from:to:)","type":"reference","isActive":true}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Draw a wayfinding path between two booths"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/fitBounds(bounds:options:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reset the map zoom to show all content"}]}]]],"header":"row","type":"table"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/expofp\/mini-map"]}],"kind":"article","metadata":{"title":"Mini-Map","roleHeading":"Article","modules":[{"name":"ExpoFP"}],"role":"article"},"hierarchy":{"paths":[["doc:\/\/com.expofp.sdk\/documentation\/ExpoFP"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Embed a floor plan preview in your content screens and expand it into a full interactive map on tap."}],"references":{"doc://com.expofp.sdk/documentation/ExpoFP/ExpoFpPlan":{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan","type":"topic","role":"symbol","url":"\/documentation\/expofp\/expofpplan","abstract":[{"type":"text","text":"An entry point to ExpoFP functionality."}],"kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExpoFpPlan","kind":"identifier"}],"navigatorTitle":[{"text":"ExpoFpPlan","kind":"identifier"}],"title":"ExpoFpPlan"},"doc://com.expofp.sdk/documentation/ExpoFP/IExpoFpPlanPresenter/planStatusPublisher":{"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","type":"topic","required":true,"role":"symbol","url":"\/documentation\/expofp\/iexpofpplanpresenter\/planstatuspublisher","abstract":[{"type":"text","text":"A publisher that notifies about plan loading statuses and navigation errors."