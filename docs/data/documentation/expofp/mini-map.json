{"hierarchy":{"paths":[["doc:\/\/com.expofp.sdk\/documentation\/ExpoFP"]]},"metadata":{"role":"article","modules":[{"name":"ExpoFP"}],"roleHeading":"Article","title":"Mini-Map"},"abstract":[{"type":"text","text":"Embed a floor plan preview in your content screens and expand it into a full interactive map on tap."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/Mini-map"},"variants":[{"paths":["\/documentation\/expofp\/mini-map"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"article","primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"A mini-map is a floor plan preview embedded directly in your app — right where attendees are already looking. Tap an exhibitor and see exactly where their booth is. Tap again to expand into a full interactive map with wayfinding directions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/www.youtube.com\/watch?v=4lCnvIRL22I","isActive":true}],"type":"paragraph"},{"inlineContent":[{"text":"The example follows a three-screen flow:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Exhibitors List","type":"text"}]},{"type":"text","text":" — loads exhibitors from the SDK and renders them as a scrollable list."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Exhibitor Detail","type":"text"}]},{"text":" — shows an inline floor plan preview with the selected booth highlighted, plus Expand and Directions buttons.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Fullscreen Plan","type":"text"}]},{"type":"text","text":" — the mini-map expands into a full interactive plan with Collapse and Directions controls."}]}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"mini-map-wireframe.svg","type":"image"}],"type":"paragraph"},{"anchor":"Quick-Start","type":"heading","level":2,"text":"Quick Start"},{"inlineContent":[{"text":"The full source is in the ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/expofp\/expofp-sdk-ios-examples","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["git clone https:\/\/github.com\/expofp\/expofp-sdk-ios-examples.git","cd expofp-sdk-ios-examples\/MiniMap","open MiniMap.xcodeproj"]},{"inlineContent":[{"text":"Build and run on a simulator or device (Xcode 16+, iOS 17+).","type":"text"}],"type":"paragraph"},{"anchor":"Architecture","type":"heading","level":2,"text":"Architecture"},{"inlineContent":[{"text":"The pattern uses ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"two independent"}]},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan","type":"reference"},{"text":" presenter instances created once and kept alive for the lifetime of the screen:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"miniMap","type":"codeVoice"},{"type":"text","text":" — powers the inline thumbnail. Touch input is disabled so it acts as a static preview."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"map","type":"codeVoice"},{"type":"text","text":" — powers the fullscreen interactive view."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both load the same expo key but operate entirely independently. SwiftUI’s "},{"type":"codeVoice","code":"matchedGeometryEffect"},{"type":"text","text":" animates the frame from the inline position to fullscreen."}]},{"syntax":"swift","code":["@MainActor","final class ContentStore: ObservableObject {","    let miniMap = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","    let map = ExpoFpPlan.createPlanPresenter(with: .expoKey(\"demo\"))","}"],"type":"codeListing"},{"text":"Plan ready → load exhibitors","level":2,"anchor":"Plan-ready-%E2%86%92-load-exhibitors","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Observe "},{"type":"reference","identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","isActive":true},{"type":"text","text":" on the mini-map presenter. When it first reaches "},{"type":"codeVoice","code":".ready"},{"type":"text","text":", strip the default SDK controls from both presenters and fetch the exhibitor list."}]},{"syntax":"swift","code":[".onReceive(store.miniMap.planStatusPublisher) { status in","    self.status = status","","    if status == .ready && exhibitors.isEmpty {","        let visibility = ExpoFpElementsVisibility(","            controls: false,","            levels: false,","            header: false,","            overlay: false","        )","        store.miniMap.setElementsVisibility(visibility)","        store.map.setElementsVisibility(visibility)","","        Task {","            exhibitors = try await store.miniMap.exhibitorsList().get()","        }","    }","}"],"type":"codeListing"},{"text":"Embed the mini-map and handle interactions","level":2,"anchor":"Embed-the-mini-map-and-handle-interactions","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Place the mini-map view inline, disable hit-testing, and attach "},{"code":"matchedGeometryEffect","type":"codeVoice"},{"type":"text","text":". When the detail view appears, highlight the booth on both presenters so the correct booth is highlighted whether you are looking at the thumbnail or the fullscreen map."}]},{"syntax":"swift","code":["store.miniMap.getView()","    .frame(height: 200)","    .allowsHitTesting(false)","    .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: !showPlan)","    .onAppear {","        store.miniMap.selectExhibitor(nameOrExternalId: exhibitor.externalId)","        store.map.selectExhibitor(nameOrExternalId: exhibitor.externalId)","    }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"strong","inlineContent":[{"text":"Expand","type":"text"}]},{"type":"text","text":" button animates to fullscreen; the "},{"type":"strong","inlineContent":[{"text":"Directions","type":"text"}]},{"type":"text","text":" button both expands and draws a wayfinding route:"}]},{"syntax":"swift","code":["\/\/ Expand","Button {","    withAnimation(.easeInOut) { showPlan = true }","} label: {","    Image(systemName: \"arrow.up.left.and.arrow.down.right\")","}","","\/\/ Directions","Button {","    withAnimation(.easeInOut) {","        showPlan = true","        store.map.selectRoute(from: .booth(\"Entrance\"), to: .booth(exhibitor.externalId))","    }","} label: {","    HStack(spacing: 4) {","        Image(.directions)","        Text(\"Directions\").foregroundStyle(.black)","    }","}"],"type":"codeListing"},{"text":"Show the fullscreen plan","level":2,"anchor":"Show-the-fullscreen-plan","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Overlay the fullscreen presenter view and mirror the ","type":"text"},{"type":"codeVoice","code":"matchedGeometryEffect"},{"text":" identifier so SwiftUI connects the two frames. The Collapse button calls ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/fitBounds(bounds:options:)","type":"reference"},{"text":" to reset the zoom before animating back.","type":"text"}]},{"syntax":"swift","code":["if showPlan {","    store.map.getView()","        .matchedGeometryEffect(id: exhibitor.id, in: namespace, isSource: showPlan)","        .ignoresSafeArea()","        .overlay(alignment: .topLeading) {","            Button {","                withAnimation(.easeInOut) {","                    showPlan = false","                    store.map.fitBounds(bounds: nil, options: nil)","                }","            } label: {","                Image(systemName: \"arrow.down.right.and.arrow.up.left\")","                    .padding()","                    .background(.thinMaterial, in: Circle())","            }","            .padding()","        }","}"],"type":"codeListing"},{"text":"SDK APIs Used","level":2,"anchor":"SDK-APIs-Used","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"API","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Purpose","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/ExpoFpPlan\/createPlanPresenter(with:additionalParams:locationProvider:messageListener:isDebugModeEnabled:)","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Create a presenter bound to an expo key","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/planStatusPublisher","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Publisher that emits plan loading status changes","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/setElementsVisibility(_:)","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Hide\/show default SDK UI controls","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/exhibitorsList()","type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"text":"Fetch the list of exhibitors for the plan","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.expofp.sdk\/documentation\/ExpoFP\/IExpoFpPlanPresenter\/getView()","type":"refe